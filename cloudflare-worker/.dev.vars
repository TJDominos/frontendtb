# .dev.vars
# This file is used for LOCAL development secrets in Cloudflare Workers.
# Variables listed here will be injected into your worker securely.
# Do NOT commit this file to version control if it contains real secrets.

MY_SECRET="your_secret_value_here"
Frontend="your_frontend_jwt_token_here"
PVK1="your_private_key_here"
PVK2="your_private_key_here"
PVK3="your_private_key_here"
